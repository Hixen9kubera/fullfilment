# ───────────────────────────────────────────────────────────────────
# Variables de entorno requeridas en producción (DigitalOcean App Platform).
# Copia este archivo como `.env` para desarrollo local.
# Marca como "Encrypted" en DigitalOcean las variables marcadas con (SECRETO).
# ───────────────────────────────────────────────────────────────────

# Anthropic – usado por el recomendador IA
ANTHROPIC_API_KEY=                          # (SECRETO) sk-ant-api03-...

# Supabase – proyecto dailyTrackMeli
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=                               # anon key — pública si tienes RLS configurado

# MySQL – tokens ML, costos, scraping Alibaba
DB_HOST=srv1249.hstgr.io
DB_PORT=3306
DB_NAME=u531713409_kubera_ml
DB_USER=                                    # (SECRETO)
DB_PASSWORD=                                # (SECRETO)

# Fernet key para descifrar access_token / refresh_token / client_secret
# en la tabla ml_tokens_dashboard. Si se pierde, los tokens son irrecuperables.
DB_ENCRYPTION_KEY=                          # (SECRETO CRÍTICO — respalda en password manager)

# Odoo
ODOO_URL=https://<tenant>.odoo.com
ODOO_DB=
ODOO_USER=
ODOO_PASSWORD=                              # (SECRETO)

# ───────────────────────────────────────────────────────────────────
# Overrides opcionales – clasificación de tamaño Full
# ───────────────────────────────────────────────────────────────────
# SIZE_PM_MAX_WEIGHT_KG=5
# SIZE_PM_MAX_SIDE_CM=45
# SIZE_PM_MAX_SUM_CM=100
